# Pexels API (free tier: 200 req/hour)
# Get your key at https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_api_key_here

# YouTube Data API v3
# OAuth client secrets file for YouTube upload
YT_CLIENT_SECRETS=client_secrets.json

# YouTube channel ID
YT_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxxxxx

# YouTube OAuth token cache
YOUTUBE_TOKEN_FILE=youtube_token.json

# Topic history (dedup)
TOPICS_FILE=youtube_shorts_topics.json
